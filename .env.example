
# =============================================================================
# AI Farm Management Agent System v2
# Environment Configuration
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Open .env and fill in your actual values
#   3. Never commit .env to git — add it to .gitignore
#   4. This file (.env.example) is safe to commit — it contains no real secrets
# =============================================================================


# -----------------------------------------------------------------------------
# LLM — REQUIRED FOR LIVE MODE
# -----------------------------------------------------------------------------

# Your OpenAI API key.
# Get one at: https://platform.openai.com/api-keys
# The key must start with sk- for the system to recognise it as valid.
# If this is missing or blank, the system runs in DEMO mode automatically —
# all agents still produce structured outputs but without live LLM reasoning.
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use for all agent LLM calls.
# Options:
#   gpt-4o         — best reasoning quality, used by default
#   gpt-4o-mini    — faster and cheaper, suitable for testing and high-volume
#   gpt-4-turbo    — alternative if gpt-4o is unavailable in your region
# Default: gpt-4o
OPENAI_MODEL=gpt-4o

# LLM temperature — controls how deterministic the responses are.
# 0.0 = fully deterministic (recommended for agents that make decisions)
# 0.7 = more creative (not recommended for this system)
# Default: 0.1
OPENAI_TEMPERATURE=0.1


# -----------------------------------------------------------------------------
# FARM IDENTITY — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Name of your farm as it will appear in all reports.
# Default: AgriSense Farm
FARM_NAME=AgriSense Farm

# Physical location of the farm — used in reports and weather context.
# Default: Central Valley, CA
FARM_LOCATION=Central Valley, CA

# Total managed farm area in acres.
# Default: 150.0
FARM_AREA_ACRES=150.0


# -----------------------------------------------------------------------------
# IRRIGATION THRESHOLDS — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Soil moisture percent below which a CRITICAL LOW MOISTURE alert is raised
# and emergency irrigation is triggered.
# Default: 20.0
CRITICAL_MOISTURE_LOW=20.0

# Soil moisture percent above which a WATERLOGGING RISK alert is raised
# and irrigation is stopped immediately.
# Default: 80.0
CRITICAL_MOISTURE_HIGH=80.0


# -----------------------------------------------------------------------------
# WEATHER THRESHOLDS — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Temperature in Celsius below which a frost risk alert is raised.
# Default: 2.0
FROST_WARNING_TEMP_C=2.0

# Temperature in Celsius above which a heat stress alert is raised.
# Default: 35.0
HEAT_STRESS_TEMP_C=35.0


# -----------------------------------------------------------------------------
# PLANNING — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Number of days ahead the harvest and planting agents plan for.
# Default: 14
PLANNING_HORIZON_DAYS=14


# -----------------------------------------------------------------------------
# PRODUCTION DATA SOURCES — OPTIONAL
# Only needed if you replace the simulation layer with real sensor APIs.
# Leave blank for demo/simulation mode.
# -----------------------------------------------------------------------------

# OpenWeatherMap API key — for real weather data
# Get one at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# CME Group DataMine API key — for live commodity prices
CME_API_KEY=

# Sentek / soil sensor gateway API endpoint
# Example: https://your-gateway.sentek.com.au/api/v1
SOIL_SENSOR_API_URL=

# Soil sensor gateway API key
SOIL_SENSOR_API_KEY=

# Google Earth Engine project ID — for Sentinel-2 NDVI crop monitoring
# Set up at: https://earthengine.google.com
GEE_PROJECT_ID=


# -----------------------------------------------------------------------------
# LOGGING — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Log level for the application.
# Options: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO
